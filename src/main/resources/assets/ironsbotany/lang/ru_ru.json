  "block.ironsbotany.spell_reservoir.tooltip": "\u0425\u0440\u0430\u043d\u0438\u0442 \u043c\u0430\u043d\u0443 ISS \u0438 \u043c\u0435\u0434\u043b\u0435\u043d\u043d\u043e \u0432\u043e\u0441\u043f\u043e\u043b\u043d\u044f\u0435\u0442 \u043c\u0430\u043d\u0443 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u043c \u0438\u0433\u0440\u043e\u043a\u0430\u043c",
  "spell.ironsbotany.mana_bloom": "\u0426\u0432\u0435\u0442\u0435\u043d\u0438\u0435 \u043c\u0430\u043d\u044b",
  "spell.ironsbotany.mana_bloom.description": "\u041f\u0440\u0438\u0437\u044b\u0432\u0430\u0435\u0442 \u043c\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0446\u0432\u0435\u0442\u044b Botania \u043d\u0430 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0435\u0439 \u0437\u0435\u043c\u043b\u0435. \u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0446\u0432\u0435\u0442\u043e\u0432 \u0438 \u0434\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0440\u0430\u0441\u0442\u0443\u0442 \u0441 \u0443\u0440\u043e\u0432\u043d\u0435\u043c.",
  "spell.ironsbotany.botanical_burst": "\u0411\u043e\u0442\u0430\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0432\u0441\u043f\u043b\u0435\u0441\u043a",
  "spell.ironsbotany.botanical_burst.description": "\u0412\u044b\u043f\u0443\u0441\u043a\u0430\u0435\u0442 \u0431\u043e\u0442\u0430\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0441\u043d\u0430\u0440\u044f\u0434, \u043d\u0430\u043d\u043e\u0441\u044f\u0449\u0438\u0439 \u043c\u0430\u0433\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0443\u0440\u043e\u043d. \u041a\u0430\u0442\u0430\u043b\u0438\u0437\u0430\u0442\u043e\u0440\u044b \u043c\u043e\u0433\u0443\u0442 \u0434\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u043f\u0440\u043e\u043d\u0438\u0437\u044b\u0432\u0430\u043d\u0438\u0435 \u0438\u043b\u0438 \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0441\u043d\u0430\u0440\u044f\u0434\u044b.",
  "spell.ironsbotany.flower_shield": "\u0426\u0432\u0435\u0442\u043e\u0447\u043d\u044b\u0439 \u0449\u0438\u0442",
  "spell.ironsbotany.flower_shield.description": "\u0421\u043e\u0437\u0434\u0430\u0451\u0442 \u043b\u0435\u043f\u0435\u0441\u0442\u043a\u043e\u0432\u044b\u0439 \u0431\u0430\u0440\u044c\u0435\u0440, \u043f\u043e\u0433\u043b\u043e\u0449\u0430\u044e\u0449\u0438\u0439 \u0443\u0440\u043e\u043d \u0438 \u0434\u0430\u044e\u0449\u0438\u0439 \u0421\u043e\u043f\u0440\u043e\u0442\u0438\u0432\u043b\u0435\u043d\u0438\u0435. \u041f\u0440\u043e\u0447\u043d\u043e\u0441\u0442\u044c \u0449\u0438\u0442\u0430 \u0440\u0430\u0441\u0442\u0451\u0442 \u0441 \u0443\u0440\u043e\u0432\u043d\u0435\u043c.",
  "spell.ironsbotany.living_root_grasp": "\u0425\u0432\u0430\u0442\u043a\u0430 \u0436\u0438\u0432\u044b\u0445 \u043a\u043e\u0440\u043d\u0435\u0439",
  "spell.ironsbotany.living_root_grasp.description": "\u041e\u043f\u0443\u0442\u044b\u0432\u0430\u0435\u0442 \u043a\u043e\u0440\u043d\u044f\u043c\u0438 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0445 \u0432\u0440\u0430\u0433\u043e\u0432, \u043d\u0430\u043a\u043b\u0430\u0434\u044b\u0432\u0430\u044f \u0417\u0430\u043c\u0435\u0434\u043b\u0435\u043d\u0438\u0435 \u0438 \u0421\u043b\u0430\u0431\u043e\u0441\u0442\u044c.",
  "spell.ironsbotany.spark_swarm": "\u0420\u043e\u0439 \u0438\u0441\u043a\u0440",
  "spell.ironsbotany.spark_swarm.description": "\u041f\u0440\u0438\u0437\u044b\u0432\u0430\u0435\u0442 \u0438\u0441\u043a\u0440\u044b \u043c\u0430\u043d\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u0440\u0430\u0449\u0430\u044e\u0442\u0441\u044f \u0432\u043e\u043a\u0440\u0443\u0433 \u0438 \u0430\u0442\u0430\u043a\u0443\u044e\u0442 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0445 \u0432\u0440\u0430\u0433\u043e\u0432. \u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0438\u0441\u043a\u0440 \u0440\u0430\u0441\u0442\u0451\u0442 \u0441 \u0443\u0440\u043e\u0432\u043d\u0435\u043c.",
  "spell.ironsbotany.runic_infusion": "\u0420\u0443\u043d\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u043d\u0430\u0441\u044b\u0449\u0435\u043d\u0438\u0435",
  "spell.ironsbotany.runic_infusion.description": "\u0414\u0430\u0451\u0442 \u0421\u0438\u043b\u0443, \u0421\u043a\u043e\u0440\u043e\u0441\u0442\u044c \u0438 \u0420\u0435\u0433\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044e. \u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u0440\u0443\u043d Botania \u0432 \u0438\u043d\u0432\u0435\u043d\u0442\u0430\u0440\u0435 \u0443\u0441\u0438\u043b\u0438\u0432\u0430\u0435\u0442 \u044d\u0444\u0444\u0435\u043a\u0442.",
  "spell.ironsbotany.petal_storm": "\u041b\u0435\u043f\u0435\u0441\u0442\u043a\u043e\u0432\u044b\u0439 \u0448\u0442\u043e\u0440\u043c",
  "spell.ironsbotany.petal_storm.description": "\u041e\u0431\u0440\u0443\u0448\u0438\u0432\u0430\u0435\u0442 \u0441\u043f\u0438\u0440\u0430\u043b\u044c\u043d\u044b\u0439 \u0448\u0442\u043e\u0440\u043c \u043b\u0435\u043f\u0435\u0441\u0442\u043a\u043e\u0432, \u043d\u0430\u043d\u043e\u0441\u044f\u0449\u0438\u0439 \u0443\u0440\u043e\u043d \u0438 \u043e\u0442\u0431\u0440\u0430\u0441\u044b\u0432\u0430\u044e\u0449\u0438\u0439 \u0431\u043b\u0438\u0436\u0430\u0439\u0448\u0438\u0445 \u0432\u0440\u0430\u0433\u043e\u0432.",
  "spell.ironsbotany.gaia_wrath": "\u0413\u043d\u0435\u0432 Gaia",
  "spell.ironsbotany.gaia_wrath.description": "\u041d\u0430\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u044f\u0440\u043e\u0441\u0442\u044c Gaia \u0434\u043b\u044f \u043d\u0430\u043d\u0435\u0441\u0435\u043d\u0438\u044f \u043e\u0433\u0440\u043e\u043c\u043d\u043e\u0433\u043e \u043c\u0430\u0441\u0441\u043e\u0432\u043e\u0433\u043e \u0443\u0440\u043e\u043d\u0430 \u0441 \u043d\u0430\u043b\u043e\u0436\u0435\u043d\u0438\u0435\u043c \u0418\u0441\u0441\u0443\u0448\u0435\u043d\u0438\u044f, \u0421\u043b\u0430\u0431\u043e\u0441\u0442\u0438 \u0438 \u0417\u0430\u043c\u0435\u0434\u043b\u0435\u043d\u0438\u044f.",
  "spell.ironsbotany.mana_rebirth": "\u041f\u0435\u0440\u0435\u0440\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u043c\u0430\u043d\u044b",
  "spell.ironsbotany.mana_rebirth.description": "\u0418\u0441\u0446\u0435\u043b\u044f\u0435\u0442 \u0437\u0430\u043a\u043b\u0438\u043d\u0430\u0442\u0435\u043b\u044f, \u0441\u043d\u0438\u043c\u0430\u0435\u0442 \u043d\u0435\u0433\u0430\u0442\u0438\u0432\u043d\u044b\u0435 \u044d\u0444\u0444\u0435\u043a\u0442\u044b \u0438 \u0434\u0430\u0451\u0442 \u0420\u0435\u0433\u0435\u043d\u0435\u0440\u0430\u0446\u0438\u044e \u0438 \u041f\u043e\u0433\u043b\u043e\u0449\u0435\u043d\u0438\u0435. \u041d\u0430 \u0432\u044b\u0441\u043e\u043a\u0438\u0445 \u0443\u0440\u043e\u0432\u043d\u044f\u0445 \u043c\u043e\u0436\u0435\u0442 \u043f\u0440\u0435\u0434\u043e\u0442\u0432\u0440\u0430\u0442\u0438\u0442\u044c \u0441\u043c\u0435\u0440\u0442\u044c.",
  "ironsbotany.spell.insufficient_botania_mana": "\u041d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e \u043c\u0430\u043d\u044b Botania! \u041d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e %s",
  "attribute.ironsbotany.mana_efficiency": "\u042d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u043c\u0430\u043d\u044b",
  "advancements.ironsbotany.root.title": "\u041f\u0440\u0438\u0440\u043e\u0434\u043d\u043e\u0435 \u043f\u0440\u043e\u0431\u0443\u0436\u0434\u0435\u043d\u0438\u0435",
  "advancements.ironsbotany.root.description": "\u0421\u043e\u0437\u0434\u0430\u0439\u0442\u0435 \u0411\u043e\u0442\u0430\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0444\u043e\u043a\u0443\u0441, \u0447\u0442\u043e\u0431\u044b \u0441\u043e\u0435\u0434\u0438\u043d\u0438\u0442\u044c \u043f\u0440\u0438\u0440\u043e\u0434\u043d\u0443\u044e \u0438 \u0442\u0430\u0439\u043d\u0443\u044e \u043c\u0430\u043d\u0443",
  "advancements.ironsbotany.first_spell.title": "\u041f\u0435\u0440\u0432\u043e\u0435 \u0446\u0432\u0435\u0442\u0435\u043d\u0438\u0435",
  "advancements.ironsbotany.first_spell.description": "\u041f\u0440\u0438\u043c\u0435\u043d\u0438\u0442\u0435 \u0441\u0432\u043e\u0451 \u043f\u0435\u0440\u0432\u043e\u0435 \u0437\u0430\u043a\u043b\u0438\u043d\u0430\u043d\u0438\u0435 \u041f\u0440\u0438\u0440\u043e\u0434\u044b",
  "advancements.ironsbotany.terrasteel_power.title": "\u0412\u043e\u0441\u0445\u043e\u0436\u0434\u0435\u043d\u0438\u0435 \u0437\u0435\u043c\u043b\u0438",
  "advancements.ironsbotany.terrasteel_power.description": "\u0412\u044b\u043a\u0443\u0439\u0442\u0435 \u043b\u0435\u0433\u0435\u043d\u0434\u0430\u0440\u043d\u044b\u0439 \u0417\u0430\u043a\u043b\u0438\u043d\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u043a\u043b\u0438\u043d\u043e\u043a Terrasteel",
  "ironsbotany.subtitle.mana_conversion": "\u041c\u0430\u043d\u0430 \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u0443\u0435\u0442\u0441\u044f",
